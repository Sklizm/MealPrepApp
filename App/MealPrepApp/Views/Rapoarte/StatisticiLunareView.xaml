<UserControl x:Class="MealPrepApp.Views.Rapoarte.StatisticiLunareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Rapoarte"
             d:DataContext="{d:DesignInstance vm:StatisticiLunareViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource CreamBrush}">

    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Cream2Brush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>
        <Style x:Key="StatNumber" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="32" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource MossDarkBrush}" />
        </Style>
        <Style x:Key="SlotChip" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Cream2Brush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Statistici lunare" Style="{StaticResource TitleText}"
                   Margin="0,0,0,16" />

        <!-- Month picker toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Luna" Style="{StaticResource BodyText}"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox Style="{StaticResource AppComboBox}" Width="150" VerticalAlignment="Center"
                      ItemsSource="{Binding Months}" DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedMonth}" />
            <ComboBox Style="{StaticResource AppComboBox}" Width="100" VerticalAlignment="Center"
                      Margin="8,0,0,0"
                      ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" />
            <Button Content="Afiseaza" Style="{StaticResource PrimaryButton}" Margin="12,0,0,0"
                    Command="{Binding AfiseazaCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
        </StackPanel>

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,8"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />

        <!-- Content -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <!-- Headline KPI tiles -->
                <UniformGrid Rows="1" Columns="3" Margin="0,0,-16,0">
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="{Binding Stats.TotalMealsPlanned, FallbackValue=0}" Style="{StaticResource StatNumber}" />
                            <TextBlock Text="Mese planificate" Style="{StaticResource BodyText}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="{Binding Stats.DistinctRecipes, FallbackValue=0}" Style="{StaticResource StatNumber}" />
                            <TextBlock Text="Retete distincte" Style="{StaticResource BodyText}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="{Binding Stats.DistinctIngredients, FallbackValue=0}" Style="{StaticResource StatNumber}" />
                            <TextBlock Text="Ingrediente distincte" Style="{StaticResource BodyText}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Per-slot breakdown -->
                <TextBlock Text="Pe categorii de masa" Style="{StaticResource SectionHeaderText}"
                           Margin="0,24,0,10" />
                <ItemsControl ItemsSource="{Binding SlotCounts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SlotChip}" Margin="0,0,10,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Label}" Style="{StaticResource BodyText}" />
                                    <TextBlock Text="{Binding Count}" FontWeight="Bold"
                                               Foreground="{StaticResource MossDarkBrush}" Margin="8,0,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Top recipes + top ingredients side by side -->
                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Top 5 retete planificate" Style="{StaticResource SectionHeaderText}"
                                   Margin="0,0,0,10" />
                        <DataGrid Style="{StaticResource AppDataGrid}"
                                  ColumnHeaderStyle="{StaticResource AppDataGridColumnHeader}"
                                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                  ItemsSource="{Binding TopRecipes}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Reteta" Binding="{Binding Title}" Width="*" />
                                <DataGridTextColumn Header="Categorie" Binding="{Binding CategoryName}" Width="130" />
                                <DataGridTextColumn Header="Planificari" Binding="{Binding PlannedCount}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Top 10 ingrediente folosite" Style="{StaticResource SectionHeaderText}"
                                   Margin="0,0,0,10" />
                        <DataGrid Style="{StaticResource AppDataGrid}"
                                  ColumnHeaderStyle="{StaticResource AppDataGridColumnHeader}"
                                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                  ItemsSource="{Binding TopIngredients}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ingredient" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Aparitii" Binding="{Binding UsageCount}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Empty state -->
        <Border Grid.Row="3" Style="{StaticResource Card}" VerticalAlignment="Center" HorizontalAlignment="Center"
                Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Margin="16" HorizontalAlignment="Center">
                <TextBlock Text="Nu sunt mese planificate in luna selectata"
                           Style="{StaticResource SectionHeaderText}" HorizontalAlignment="Center" />
                <TextBlock Text="Planifica mese din sectiunea Planificare pentru a vedea statistici aici."
                           Style="{StaticResource SmallMutedText}" Margin="0,6,0,0"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="380" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
