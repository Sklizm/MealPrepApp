<Window x:Class="MealPrepApp.Views.StartupLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Se incarca aplicatia"
        Width="430" Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        FontFamily="{StaticResource AppFontFamily}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                            ResizeBorderThickness="0" CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource CreamBrush}"
            BorderBrush="{StaticResource MossBrush}"
            BorderThickness="1"
            CornerRadius="20"
            Padding="34">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="0"
                              Color="#552E2820" />
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid Width="84" Height="84" Margin="0,0,0,22">
                <Ellipse Stroke="{StaticResource MossLightBrush}"
                         StrokeThickness="7"
                         Opacity="0.35" />
                <Path Stroke="{StaticResource MossDarkBrush}"
                      StrokeThickness="7"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 42,5 A 37,37 0 0 1 79,42"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <RotateTransform x:Name="StartupSpinnerRotate" />
                    </Path.RenderTransform>
                    <Path.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="StartupSpinnerRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360"
                                                     Duration="0:0:0.9" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Path.Triggers>
                </Path>
            </Grid>

            <TextBlock Text="Se incarca aplicatia"
                       Style="{StaticResource TitleText}"
                       FontSize="22"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Pregatim tabloul de bord..."
                       Foreground="{StaticResource MossDarkBrush}"
                       FontSize="{StaticResource FontSizeBody}"
                       TextAlignment="Center"
                       Margin="0,10,0,0" />
            <TextBlock Text="Dureaza doar cateva secunde."
                       Foreground="{StaticResource DarkBrush}"
                       Opacity="0.72"
                       FontSize="{StaticResource FontSizeSmall}"
                       TextAlignment="Center"
                       Margin="0,18,0,0" />
        </StackPanel>
    </Border>
</Window>
