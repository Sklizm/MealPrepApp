<UserControl x:Class="MealPrepApp.Views.Ingrediente.IngredienteListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Ingrediente"
             xmlns:models="clr-namespace:MealPrepApp.Models"
             d:DataContext="{d:DesignInstance vm:IngredienteListViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource CreamBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Ingrediente" Style="{StaticResource TitleText}"
                       VerticalAlignment="Center" Margin="0,0,24,0" />

            <TextBox Grid.Column="1" Style="{StaticResource AppSearchBox}"
                     Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                     Tag="{Binding ClearSearchCommand}"
                     VerticalAlignment="Center" MaxWidth="320" HorizontalAlignment="Left" />

            <ComboBox Grid.Column="2" Style="{StaticResource AppComboBox}"
                      ItemsSource="{Binding Categories}" DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedCategory}"
                      VerticalAlignment="Center" Width="180" Margin="8,0,0,0" />

            <Button Grid.Column="3" Content="+ Adauga ingredient" Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddIngredientCommand}" Margin="8,0,0,0" />
        </Grid>

        <!-- Error slot -->
        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,8"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />

        <!-- List / empty -->
        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding Ingredients.Count, Converter={StaticResource NonEmptyToVisibility}}">
                <ItemsControl ItemsSource="{Binding IngredientsView}">
                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource MossBrush}" CornerRadius="3"
                                            Padding="10,4" Margin="0,10,0,6" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource CreamBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="{StaticResource FontSizeBody}" />
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Ingredient}">
                            <Border Background="{StaticResource Cream2Brush}" CornerRadius="6"
                                    Padding="12,8" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="32" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                               Style="{StaticResource BodyText}"
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="1" Background="{StaticResource DarkBrush}"
                                            CornerRadius="3" Padding="6,2" Margin="0,0,8,0"
                                            Visibility="{Binding DefaultUnitAbbreviation, Converter={StaticResource NotNullToVisibility}}">
                                        <TextBlock Text="{Binding DefaultUnitAbbreviation}"
                                                   Foreground="{StaticResource CreamBrush}"
                                                   FontSize="{StaticResource FontSizeSmall}" />
                                    </Border>
                                    <Button Grid.Column="2" Content="Nutritie" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                            Command="{Binding DataContext.EditNutritionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="3" Content="✕" Width="24" Height="24" Padding="0"
                                            FontSize="11" Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource DangerBrush}" Cursor="Hand"
                                            ToolTip="Sterge ingredientul"
                                            Command="{Binding DataContext.DeleteIngredientCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Style="{StaticResource Card}" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding Ingredients.Count, Converter={StaticResource EmptyToVisibility}}">
                <StackPanel Margin="16" HorizontalAlignment="Center">
                    <TextBlock Text="Niciun ingredient" Style="{StaticResource SectionHeaderText}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Adauga primul ingredient pentru a incepe."
                               Style="{StaticResource SmallMutedText}" Margin="0,6,0,0"
                               HorizontalAlignment="Center" />
                    <Button Content="+ Adauga ingredient" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center" Margin="0,14,0,0"
                            Command="{Binding AddIngredientCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
