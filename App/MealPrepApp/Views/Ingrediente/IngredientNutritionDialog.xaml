<Window x:Class="MealPrepApp.Views.Ingrediente.IngredientNutritionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Ingrediente"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        d:DataContext="{d:DesignInstance vm:IngredientNutritionDialogViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Nutritie ingredient"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CreamBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        Loaded="OnLoaded">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44" GlassFrameThickness="0"
                            ResizeBorderThickness="0" CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource DarkBrush}" Height="44">
            <Grid>
                <TextBlock Text="Nutritie ingredient" Foreground="{StaticResource CreamBrush}"
                           FontSize="{StaticResource FontSizeAction}" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="16,0,0,0" />
                <Button HorizontalAlignment="Right" Content="✕"
                        Style="{StaticResource WindowCloseButton}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="OnChromeCloseClick" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="20">
            <TextBlock Text="{Binding IngredientName}" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,10" />
            <TextBlock Text="Completeaza valorile pentru o cantitate standard. Retetele calculeaza totalul doar cand unitatile pot fi convertite direct."
                       Style="{StaticResource SmallMutedText}" TextWrapping="Wrap" Margin="0,0,0,14" />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Cantitate baza" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource AppTextBox}"
                             Text="{Binding BasisQuantity, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Unitate baza" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
                    <ComboBox Style="{StaticResource AppComboBox}"
                              ItemsSource="{Binding Units}" DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedUnit}" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Calorii" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,0,0,10"
                     Text="{Binding Calories, UpdateSourceTrigger=PropertyChanged}" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Proteine (g)" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource AppTextBox}" Text="{Binding ProteinGrams, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Carbohidrati (g)" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource AppTextBox}" Text="{Binding CarbsGrams, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Grasimi (g)" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource AppTextBox}" Text="{Binding FatGrams, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,8,0,0"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource Cream2Brush}" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Renunta" Style="{StaticResource SecondaryButton}"
                        Click="OnCancelClick" />
                <Button Content="Salveaza" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
