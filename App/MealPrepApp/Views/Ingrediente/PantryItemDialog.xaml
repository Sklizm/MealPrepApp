<Window x:Class="MealPrepApp.Views.Ingrediente.PantryItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Ingrediente"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        d:DataContext="{d:DesignInstance vm:PantryItemDialogViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="{Binding Title}"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CreamBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        Loaded="OnLoaded">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44" GlassFrameThickness="0"
                            ResizeBorderThickness="0" CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource DarkBrush}" Height="44">
            <Grid>
                <TextBlock Text="{Binding Title}" Foreground="{StaticResource CreamBrush}"
                           FontSize="{StaticResource FontSizeAction}" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="16,0,0,0" />
                <Button HorizontalAlignment="Right" Content="✕"
                        Style="{StaticResource WindowCloseButton}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="OnChromeCloseClick" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="20">
            <TextBlock Text="Ingredient *" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <ComboBox Style="{StaticResource AppComboBox}" Margin="0,0,0,12"
                      IsEditable="True" IsTextSearchEnabled="True"
                      ItemsSource="{Binding Ingredients}" DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedIngredient}"
                      IsEnabled="{Binding IsEdit, Converter={StaticResource InverseBool}}" />

            <TextBlock Text="Unitate *" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <ComboBox Style="{StaticResource AppComboBox}" Margin="0,0,0,12"
                      ItemsSource="{Binding Units}" DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedUnit}"
                      IsEnabled="{Binding IsEdit, Converter={StaticResource InverseBool}}" />

            <TextBlock Text="Cantitate *" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,0,0,4"
                     Width="140" HorizontalAlignment="Left"
                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,8,0,0"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource Cream2Brush}" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Renunta" Style="{StaticResource SecondaryButton}"
                        Click="OnCancelClick" />
                <Button Content="Salveaza" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
