<UserControl x:Class="MealPrepApp.Views.Ingrediente.ShoppingListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Ingrediente"
             d:DataContext="{d:DesignInstance vm:ShoppingListViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource CreamBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Lista de cumparaturi" Style="{StaticResource TitleText}"
                   Margin="0,0,0,16" />

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="De la" Style="{StaticResource BodyText}"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}"
                        VerticalAlignment="Center" Width="140" />
            <TextBlock Grid.Column="2" Text="pana la" Style="{StaticResource BodyText}"
                       VerticalAlignment="Center" Margin="12,0,8,0" />
            <DatePicker Grid.Column="3" SelectedDate="{Binding EndDate}"
                        VerticalAlignment="Center" Width="140" />

            <Button Grid.Column="4" Content="Genereaza" Style="{StaticResource PrimaryButton}"
                    Command="{Binding GenerateCommand}" Margin="12,0,0,0" />

            <Button Grid.Column="6" Content="Export Excel" Style="{StaticResource SecondaryButton}"
                    Command="{Binding ExportExcelCommand}"
                    IsEnabled="{Binding Rows.Count, Converter={StaticResource NonEmptyToBool}}" />
            <Button Grid.Column="7" Content="Tipareste" Style="{StaticResource SecondaryButton}"
                    Click="OnPrintClick" Margin="8,0,0,0"
                    IsEnabled="{Binding Rows.Count, Converter={StaticResource NonEmptyToBool}}" />
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,8"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />

        <Grid Grid.Row="3">
            <DataGrid x:Name="ResultsGrid"
                      Style="{StaticResource AppDataGrid}"
                      ColumnHeaderStyle="{StaticResource AppDataGridColumnHeader}"
                      ItemsSource="{Binding Rows}"
                      Visibility="{Binding Rows.Count, Converter={StaticResource NonEmptyToVisibility}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ingredient" Binding="{Binding IngredientName}" Width="*" />
                    <DataGridTextColumn Header="Necesar" Binding="{Binding NeededQty, StringFormat={}{0:0.##}}" Width="100" />
                    <DataGridTextColumn Header="In frigider" Binding="{Binding OnHandQty, StringFormat={}{0:0.##}}" Width="110" />
                    <DataGridTextColumn Header="De cumparat" Binding="{Binding ToBuyQty, StringFormat={}{0:0.##}}" Width="120" />
                    <DataGridTextColumn Header="Unitate" Binding="{Binding UnitAbbreviation}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Style="{StaticResource Card}" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding Rows.Count, Converter={StaticResource EmptyToVisibility}}">
                <StackPanel Margin="16" HorizontalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHeaderText}">
                                <Setter Property="Text" Value="Selecteaza un interval si apasa Genereaza" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasGenerated}" Value="True">
                                        <Setter Property="Text" Value="Nu sunt mese planificate in intervalul selectat" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="Adauga mese din sectiunea Planificare pentru a vedea ce ai nevoie sa cumperi."
                               Style="{StaticResource SmallMutedText}" Margin="0,6,0,0"
                               HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="380" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
