<UserControl x:Class="MealPrepApp.Views.Ingrediente.FrigiderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Ingrediente"
             xmlns:models="clr-namespace:MealPrepApp.Models"
             d:DataContext="{d:DesignInstance vm:FrigiderViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource CreamBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Frigider" Style="{StaticResource TitleText}"
                       VerticalAlignment="Center" />

            <Button Grid.Column="2" Content="+ Adauga in frigider" Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddItemCommand}" />
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,8"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />

        <Grid Grid.Row="2">
            <DataGrid Style="{StaticResource AppDataGrid}"
                      ColumnHeaderStyle="{StaticResource AppDataGridColumnHeader}"
                      ItemsSource="{Binding Items}"
                      Visibility="{Binding Items.Count, Converter={StaticResource NonEmptyToVisibility}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ingredient" Binding="{Binding IngredientName}" Width="*" />
                    <DataGridTextColumn Header="Cantitate" Binding="{Binding Quantity, StringFormat={}{0:0.##}}" Width="100" />
                    <DataGridTextColumn Header="Unitate" Binding="{Binding UnitAbbreviation}" Width="100" />
                    <DataGridTextColumn Header="Adaugat"
                                        Binding="{Binding AddedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                        Width="100" />
                    <DataGridTemplateColumn Header="" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:PantryItem}">
                                <StackPanel Orientation="Horizontal" Margin="4,0">
                                    <Button Content="Editeaza" Style="{StaticResource SecondaryButton}"
                                            Padding="8,3" FontSize="11"
                                            Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Sterge" Style="{StaticResource DangerButton}"
                                            Padding="8,3" FontSize="11" Margin="6,0,0,0"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Style="{StaticResource Card}" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding Items.Count, Converter={StaticResource EmptyToVisibility}}">
                <StackPanel Margin="16" HorizontalAlignment="Center">
                    <TextBlock Text="Frigiderul este gol" Style="{StaticResource SectionHeaderText}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Adauga produsele pe care le ai."
                               Style="{StaticResource SmallMutedText}" Margin="0,6,0,0"
                               HorizontalAlignment="Center" />
                    <Button Content="+ Adauga in frigider" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center" Margin="0,14,0,0"
                            Command="{Binding AddItemCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
