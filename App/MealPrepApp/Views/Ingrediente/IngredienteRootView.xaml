<UserControl x:Class="MealPrepApp.Views.Ingrediente.IngredienteRootView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Ingrediente"
             xmlns:views="clr-namespace:MealPrepApp.Views.Ingrediente"
             d:DataContext="{d:DesignInstance vm:IngredienteRootViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource CreamBrush}">

    <UserControl.Resources>
        <Style x:Key="SideNavRadio" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeMenu}" />
            <Setter Property="Foreground" Value="{StaticResource CreamBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="Transparent" Padding="20,10">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource MossBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource DarkBrush}">
            <StackPanel Margin="0,16,0,0">
                <RadioButton Content="Toate" Style="{StaticResource SideNavRadio}" GroupName="IngFilter"
                             Command="{Binding ShowToateCommand}"
                             IsChecked="{Binding ActiveSection, Mode=OneWay, Converter={StaticResource StringEquals}, ConverterParameter=Toate}" />
                <RadioButton Content="Categorii" Style="{StaticResource SideNavRadio}" GroupName="IngFilter"
                             Command="{Binding ShowCategoriiCommand}"
                             IsChecked="{Binding ActiveSection, Mode=OneWay, Converter={StaticResource StringEquals}, ConverterParameter=Categorii}" />
                <RadioButton Content="Frigider" Style="{StaticResource SideNavRadio}" GroupName="IngFilter"
                             Command="{Binding ShowFrigiderCommand}"
                             IsChecked="{Binding ActiveSection, Mode=OneWay, Converter={StaticResource StringEquals}, ConverterParameter=Frigider}" />
                <RadioButton Content="Lista de cumparaturi" Style="{StaticResource SideNavRadio}" GroupName="IngFilter"
                             Command="{Binding ShowCumparaturiCommand}"
                             IsChecked="{Binding ActiveSection, Mode=OneWay, Converter={StaticResource StringEquals}, ConverterParameter=Cumparaturi}" />
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentSubView}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:IngredienteListViewModel}">
                    <views:IngredienteListView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:FrigiderViewModel}">
                    <views:FrigiderView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ShoppingListViewModel}">
                    <views:ShoppingListView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</UserControl>
