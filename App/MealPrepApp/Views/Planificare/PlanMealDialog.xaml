<Window x:Class="MealPrepApp.Views.Planificare.PlanMealDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Planificare"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        d:DataContext="{d:DesignInstance vm:PlanMealDialogViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="{Binding Title}"
        Width="440" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CreamBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        Loaded="OnLoaded">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44" GlassFrameThickness="0"
                            ResizeBorderThickness="0" CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource DarkBrush}" Height="44">
            <Grid>
                <TextBlock Text="{Binding Title}" Foreground="{StaticResource CreamBrush}"
                           FontSize="{StaticResource FontSizeAction}" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="16,0,0,0" />
                <Button HorizontalAlignment="Right" Content="✕"
                        Style="{StaticResource WindowCloseButton}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="OnChromeCloseClick" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="20">
            <!-- Recipe: editable autocomplete on add, fixed label on edit -->
            <TextBlock Text="Reteta *" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <ComboBox Style="{StaticResource AppComboBox}" Margin="0,0,0,12"
                      IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                      Text="{Binding RecipeSearchTerm, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{Binding RecipeResults}" DisplayMemberPath="Title"
                      SelectedItem="{Binding SelectedRecipe}"
                      Visibility="{Binding CanPickRecipe, Converter={StaticResource BoolToVisibility}}" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,0,0,12" IsReadOnly="True"
                     Text="{Binding FixedRecipeTitle, Mode=OneWay}"
                     Visibility="{Binding IsEdit, Converter={StaticResource BoolToVisibility}}" />

            <!-- Meal slot -->
            <TextBlock Text="Masa *" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <ComboBox Style="{StaticResource AppComboBox}" Margin="0,0,0,12"
                      ItemsSource="{Binding Categories}" DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedCategory}" />

            <!-- Date -->
            <TextBlock Text="Data *" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <DatePicker SelectedDate="{Binding PlannedDate}" Margin="0,0,0,12"
                        Width="160" HorizontalAlignment="Left" />

            <!-- Servings (optional) -->
            <TextBlock Text="Portii (optional)" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,0,0,12"
                     Width="100" HorizontalAlignment="Left"
                     Text="{Binding Servings, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

            <!-- Notes (optional) -->
            <TextBlock Text="Notite (optional)" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <TextBox Style="{StaticResource AppTextBox}"
                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"
                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,8,0,0"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource Cream2Brush}" Padding="20,12">
            <Grid>
                <!-- Sterge on the left, edit mode only -->
                <Button Content="Sterge" Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left"
                        Command="{Binding DeleteCommand}"
                        Visibility="{Binding IsEdit, Converter={StaticResource BoolToVisibility}}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Renunta" Style="{StaticResource SecondaryButton}"
                            Click="OnCancelClick" />
                    <Button Content="Salveaza" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
