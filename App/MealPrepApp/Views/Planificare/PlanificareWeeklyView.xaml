<UserControl x:Class="MealPrepApp.Views.Planificare.PlanificareWeeklyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Planificare"
             d:DataContext="{d:DesignInstance vm:PlanificareWeeklyViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource CreamBrush}">

    <UserControl.Resources>
        <!-- Clickable (date, slot) cell — the "add here" surface -->
        <Style x:Key="WeekCellButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource Cream2Brush}"
                                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0.5"
                                Padding="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource MossLightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- A planned-meal chip, coloured by meal slot (CategoryID 1–4) -->
        <Style x:Key="MealChipButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Tag" Value="{StaticResource MossBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Tag}" CornerRadius="3" Padding="5,2">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{StaticResource CreamBrush}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CategoryID}" Value="1">
                    <Setter Property="Tag" Value="{StaticResource MealBreakfastBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CategoryID}" Value="2">
                    <Setter Property="Tag" Value="{StaticResource MealLunchBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CategoryID}" Value="3">
                    <Setter Property="Tag" Value="{StaticResource MealDinnerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CategoryID}" Value="4">
                    <Setter Property="Tag" Value="{StaticResource MealSnackBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20,4,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Week navigation -->
        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
            <Button DockPanel.Dock="Left" Content="◀" Style="{StaticResource SecondaryButton}"
                    Command="{Binding PrevWeekCommand}" />
            <Button DockPanel.Dock="Left" Content="Saptamana curenta" Style="{StaticResource SecondaryButton}"
                    Margin="8,0,0,0" Command="{Binding ThisWeekCommand}" />
            <Button DockPanel.Dock="Right" Content="▶" Style="{StaticResource SecondaryButton}"
                    Command="{Binding NextWeekCommand}" />
            <TextBlock Text="{Binding WeekLabel}" Style="{StaticResource BodyText}"
                       FontWeight="Bold" FontSize="{StaticResource FontSizeAction}"
                       VerticalAlignment="Center" Margin="20,0,0,0" />
        </DockPanel>

        <!-- Slot column headers -->
        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ItemsControl Grid.Column="1" ItemsSource="{Binding SlotHeaders}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Style="{StaticResource SmallMutedText}"
                                   HorizontalAlignment="Center" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Day rows -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource DarkBrush}"
                                    BorderBrush="{StaticResource DividerBrush}" BorderThickness="0.5">
                                <TextBlock Text="{Binding DayLabel}" Foreground="{StaticResource CreamBrush}"
                                           FontFamily="{StaticResource AppFontFamily}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>

                            <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource WeekCellButton}"
                                                Command="{Binding DataContext.AddInCellCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <ItemsControl ItemsSource="{Binding Entries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource MealChipButton}"
                                                                Content="{Binding RecipeTitle}"
                                                                Command="{Binding DataContext.EditEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
