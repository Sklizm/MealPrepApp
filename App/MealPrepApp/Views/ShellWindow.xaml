<Window x:Class="MealPrepApp.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MealPrepApp.ViewModels"
        xmlns:shellvm="clr-namespace:MealPrepApp.ViewModels.Shell"
        xmlns:authvm="clr-namespace:MealPrepApp.ViewModels.Auth"
        xmlns:retetevm="clr-namespace:MealPrepApp.ViewModels.Retete"
        xmlns:ingvm="clr-namespace:MealPrepApp.ViewModels.Ingrediente"
        xmlns:planvm="clr-namespace:MealPrepApp.ViewModels.Planificare"
        xmlns:rapvm="clr-namespace:MealPrepApp.ViewModels.Rapoarte"
        xmlns:views="clr-namespace:MealPrepApp.Views"
        xmlns:auth="clr-namespace:MealPrepApp.Views.Auth"
        xmlns:retete="clr-namespace:MealPrepApp.Views.Retete"
        xmlns:ingrediente="clr-namespace:MealPrepApp.Views.Ingrediente"
        xmlns:planificare="clr-namespace:MealPrepApp.Views.Planificare"
        xmlns:rapoarte="clr-namespace:MealPrepApp.Views.Rapoarte"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Planificator de Retete si Mese"
        Width="1040" Height="700"
        MinWidth="940" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{StaticResource CreamBrush}"
        FontFamily="{StaticResource AppFontFamily}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44" GlassFrameThickness="0"
                            ResizeBorderThickness="6" CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar with user dropdown + window chrome buttons -->
        <Border Grid.Row="0" Background="{StaticResource DarkBrush}" Height="44">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Planificator de Retete si Mese"
                           Foreground="{StaticResource CreamBrush}"
                           FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                           VerticalAlignment="Center" HorizontalAlignment="Left"
                           Margin="16,0,0,0" />

                <Menu Grid.Column="1"
                      Style="{StaticResource AppMenu}"
                      VerticalAlignment="Center"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <MenuItem Header="{Binding CurrentUsername}"
                              Style="{StaticResource AppMenuItem}"
                              ItemContainerStyle="{StaticResource AppMenuItem}">
                        <MenuItem Header="Profil" Command="{Binding ShowProfileCommand}" />
                        <MenuItem Header="Iesi din cont" Command="{Binding SignOutCommand}" />
                    </MenuItem>
                </Menu>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="─" Style="{StaticResource WindowChromeButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="OnMinimizeClick" />
                    <Button x:Name="MaxRestoreButton" Content="▢"
                            Style="{StaticResource WindowChromeButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="OnMaximizeRestoreClick" />
                    <Button Content="✕" Style="{StaticResource WindowCloseButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="OnCloseClick" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab strip -->
        <Border Grid.Row="1" Background="{StaticResource DarkBrush}" Height="44">
            <StackPanel Orientation="Horizontal" Margin="10,0" VerticalAlignment="Center">
                <RadioButton Content="Acasa" Style="{StaticResource TabRadio}" GroupName="Tabs"
                             Command="{Binding ShowAcasaCommand}"
                             IsChecked="{Binding ActiveTab, Mode=OneWay, Converter={StaticResource StringEquals}, ConverterParameter=Acasa}" />
                <RadioButton Content="Retete" Style="{StaticResource TabRadio}" GroupName="Tabs"
                             Command="{Binding ShowReteteCommand}"
                             IsChecked="{Binding ActiveTab, Mode=OneWay, Converter={StaticResource StringEquals}, ConverterParameter=Retete}" />
                <RadioButton Content="Ingrediente" Style="{StaticResource TabRadio}" GroupName="Tabs"
                             Command="{Binding ShowIngredienteCommand}"
                             IsChecked="{Binding ActiveTab, Mode=OneWay, Converter={StaticResource StringEquals}, ConverterParameter=Ingrediente}" />
                <RadioButton Content="Planificare" Style="{StaticResource TabRadio}" GroupName="Tabs"
                             Command="{Binding ShowPlanificareCommand}"
                             IsChecked="{Binding ActiveTab, Mode=OneWay, Converter={StaticResource StringEquals}, ConverterParameter=Planificare}" />
                <RadioButton Content="Rapoarte" Style="{StaticResource TabRadio}" GroupName="Tabs"
                             Command="{Binding ShowRapoarteCommand}"
                             IsChecked="{Binding ActiveTab, Mode=OneWay, Converter={StaticResource StringEquals}, ConverterParameter=Rapoarte}" />
            </StackPanel>
        </Border>

        <!-- Content region -->
        <ContentControl Grid.Row="2" Content="{Binding CurrentView}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:AcasaViewModel}">
                    <views:AcasaView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type shellvm:PlaceholderViewModel}">
                    <views:PlaceholderView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type authvm:ProfileViewModel}">
                    <auth:ProfileView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type retetevm:ReteteListViewModel}">
                    <retete:ReteteListView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type retetevm:ReteteDetailViewModel}">
                    <retete:ReteteDetailView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type retetevm:ReteteEditorViewModel}">
                    <retete:ReteteEditorView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type ingvm:IngredienteRootViewModel}">
                    <ingrediente:IngredienteRootView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type planvm:PlanificareRootViewModel}">
                    <planificare:PlanificareRootView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type rapvm:RapoarteRootViewModel}">
                    <rapoarte:RapoarteRootView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{StaticResource DarkBrush}" Height="28">
            <Grid Margin="12,0">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource CreamBrush}"
                           FontSize="{StaticResource FontSizeSmall}"
                           VerticalAlignment="Center" HorizontalAlignment="Left" />
                <TextBlock Text="Railean Margarita · P-2331"
                           Foreground="{StaticResource MossLightBrush}"
                           FontSize="{StaticResource FontSizeSmall}"
                           VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>
        </Border>

    </Grid>
</Window>
