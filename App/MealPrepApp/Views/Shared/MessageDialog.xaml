<Window x:Class="MealPrepApp.Views.Shared.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Mesaj"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CreamBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        AllowsTransparency="False"
        ShowInTaskbar="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44" GlassFrameThickness="0"
                            ResizeBorderThickness="0" CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header — DarkBrush by default; Error variant swaps to DangerBrush in code-behind -->
            <Border Grid.Row="0" x:Name="HeaderBorder"
                    Background="{StaticResource DarkBrush}" Height="44">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock x:Name="HeaderGlyph"
                                   Text=""
                                   Foreground="{StaticResource CreamBrush}"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   Visibility="Collapsed" />
                        <TextBlock x:Name="HeaderText"
                                   Foreground="{StaticResource CreamBrush}"
                                   FontSize="{StaticResource FontSizeAction}" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button HorizontalAlignment="Right"
                            Style="{StaticResource WindowCloseButton}"
                            Content="✕"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="OnCloseClick" />
                </Grid>
            </Border>

            <!-- Message -->
            <StackPanel Grid.Row="1" Margin="20,18,20,18">
                <TextBlock x:Name="MessageBody"
                           Style="{StaticResource BodyText}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource Cream2Brush}" Padding="20,12">
                <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Renunta"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnCancelClick"
                            Visibility="Collapsed" />
                    <Button x:Name="OkButton" Content="OK"
                            Style="{StaticResource PrimaryButton}"
                            Margin="10,0,0,0"
                            Click="OnOkClick"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
