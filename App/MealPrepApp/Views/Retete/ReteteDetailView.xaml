<UserControl x:Class="MealPrepApp.Views.Retete.ReteteDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Retete"
             xmlns:models="clr-namespace:MealPrepApp.Models"
             d:DataContext="{d:DesignInstance vm:ReteteDetailViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource CreamBrush}">

    <Grid Margin="32">
        <!-- Error slot (shown when the recipe could not be loaded) -->
        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                   TextWrapping="Wrap" VerticalAlignment="Top"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding Recipe, Converter={StaticResource NotNullToVisibility}}">
            <StackPanel DataContext="{Binding Recipe}" MaxWidth="760" HorizontalAlignment="Left">

                <!-- Header: title + actions -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Title}" Style="{StaticResource TitleText}"
                               TextWrapping="Wrap" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- DataContext here is RecipeFull; commands live on the ReteteDetailViewModel -->
                        <Button Command="{Binding DataContext.ToggleFavoriteCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Setter Property="Content" Value="☆ Adauga la favorite" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsFavorite,
                                                     RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Content" Value="★ Favorit" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Editeaza" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                Command="{Binding DataContext.EditCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        <Button Content="Sterge" Style="{StaticResource DangerButton}" Margin="8,0,0,0"
                                Command="{Binding DataContext.DeleteCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        <Button Content="Inapoi" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                Command="{Binding DataContext.BackCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </StackPanel>
                </Grid>

                <!-- Meta row: category badge + times + servings + author -->
                <WrapPanel Margin="0,12,0,0">
                    <Border Background="{StaticResource MossBrush}" CornerRadius="3" Padding="8,3"
                            Margin="0,0,12,0"
                            Visibility="{Binding CategoryName, Converter={StaticResource NotNullToVisibility}}">
                        <TextBlock Text="{Binding CategoryName}" Foreground="{StaticResource CreamBrush}"
                                   FontSize="{StaticResource FontSizeSmall}" />
                    </Border>
                    <TextBlock Style="{StaticResource SmallMutedText}" Margin="0,0,12,0"
                               Text="{Binding PrepTimeMinutes, StringFormat='Preparare: {0} min', TargetNullValue='Preparare: —'}" />
                    <TextBlock Style="{StaticResource SmallMutedText}" Margin="0,0,12,0"
                               Text="{Binding CookTimeMinutes, StringFormat='Gatire: {0} min', TargetNullValue='Gatire: —'}" />
                    <TextBlock Style="{StaticResource SmallMutedText}" Margin="0,0,12,0"
                               Text="{Binding Servings, StringFormat='Portii: {0}', TargetNullValue='Portii: —'}" />
                    <TextBlock Style="{StaticResource SmallMutedText}"
                               Text="{Binding AuthorUsername, StringFormat='Autor: {0}'}" />
                </WrapPanel>

                <!-- Description -->
                <TextBlock Text="Descriere" Style="{StaticResource SectionHeaderText}" Margin="0,24,0,6"
                           Visibility="{Binding Description, Converter={StaticResource NotNullToVisibility}}" />
                <TextBlock Text="{Binding Description}" Style="{StaticResource BodyText}" TextWrapping="Wrap"
                           Visibility="{Binding Description, Converter={StaticResource NotNullToVisibility}}" />

                <!-- Instructions -->
                <TextBlock Text="Instructiuni" Style="{StaticResource SectionHeaderText}" Margin="0,24,0,6" />
                <TextBlock Text="{Binding Instructions}" Style="{StaticResource BodyText}" TextWrapping="Wrap" />

                <!-- Ingredients -->
                <TextBlock Text="Ingrediente" Style="{StaticResource SectionHeaderText}" Margin="0,24,0,6" />
                <Border Style="{StaticResource Card}">
                    <ItemsControl ItemsSource="{Binding Ingredients}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:RecipeIngredientLine}">
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="3*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding IngredientName}"
                                               Style="{StaticResource BodyText}" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource BodyText}"
                                               HorizontalAlignment="Right" Margin="0,0,8,0"
                                               Text="{Binding Quantity, StringFormat='{}{0:0.##}'}" />
                                    <TextBlock Grid.Column="2" Text="{Binding UnitAbbreviation}"
                                               Style="{StaticResource SmallMutedText}" Margin="0,0,12,0" />
                                    <TextBlock Grid.Column="3" Text="{Binding Notes}"
                                               Style="{StaticResource SmallMutedText}" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <TextBlock Text="Aceasta reteta nu are ingrediente."
                           Style="{StaticResource SmallMutedText}" Margin="0,6,0,0"
                           Visibility="{Binding Ingredients, Converter={StaticResource EmptyToVisibility}}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
