<UserControl x:Class="MealPrepApp.Views.Auth.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Auth"
             d:DataContext="{d:DesignInstance vm:RegisterViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <StackPanel>
        <TextBlock Text="Cont nou" Style="{StaticResource TitleText}" Margin="0,0,0,18" />

        <TextBlock Text="Nume utilizator" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
        <TextBox Style="{StaticResource AppTextBox}" Margin="0,0,0,12"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="Email" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
        <TextBox Style="{StaticResource AppTextBox}" Margin="0,0,0,12"
                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="Parola" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
        <PasswordBox x:Name="PasswordBox" Style="{StaticResource AppPasswordBox}" Margin="0,0,0,12" />

        <TextBlock Text="Confirma parola" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
        <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource AppPasswordBox}" Margin="0,0,0,12" />

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />

        <Button Content="Inregistreaza-te" Style="{StaticResource PrimaryButton}" Height="38"
                Click="OnRegisterClick"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />

        <Button Content="Ai cont? Conecteaza-te" Style="{StaticResource LinkButton}"
                Margin="0,18,0,0" Command="{Binding SwitchToLoginCommand}" />
    </StackPanel>
</UserControl>
