<Window x:Class="MealPrepApp.Views.Auth.ForgotPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MealPrepApp.ViewModels.Auth"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        d:DataContext="{d:DesignInstance vm:ForgotPasswordViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Resetare parola"
        Width="410" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CreamBrush}"
        FontFamily="{StaticResource AppFontFamily}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44" GlassFrameThickness="0"
                            ResizeBorderThickness="0" CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource DarkBrush}" Height="44">
            <Grid>
                <TextBlock Text="Resetare parola" Foreground="{StaticResource CreamBrush}"
                           FontSize="{StaticResource FontSizeAction}" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="16,0,0,0" />
                <Button HorizontalAlignment="Right" Content="✕"
                        Style="{StaticResource WindowCloseButton}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="OnChromeCloseClick" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="20">
            <TextBlock Text="Introdu utilizatorul/emailul si emailul contului. Pentru proiectul local, parola se reseteaza direct in baza de date."
                       Foreground="{StaticResource DarkBrush}"
                       Opacity="0.78"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14" />

            <TextBlock Text="Utilizator sau email" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,0,0,12"
                     Text="{Binding Identifier, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Email cont" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,0,0,12"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Parola noua" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource AppPasswordBox}" Margin="0,0,0,12" />

            <TextBlock Text="Confirma parola noua" Style="{StaticResource SmallMutedText}" Margin="0,0,0,4" />
            <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource AppPasswordBox}" Margin="0,0,0,4" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,8,0,0"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource Cream2Brush}" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Renunta" Style="{StaticResource SecondaryButton}"
                        Click="OnCancelClick" />
                <Button Content="Reseteaza parola" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                        Click="OnResetClick"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
