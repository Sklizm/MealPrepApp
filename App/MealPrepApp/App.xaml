<Application x:Class="MealPrepApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MealPrepApp.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:InverseBooleanConverter x:Key="InverseBool" />
            <conv:NotNullToVisibilityConverter x:Key="NotNullToVisibility" />
            <conv:EmptyCollectionToVisibilityConverter x:Key="EmptyToVisibility" />
            <conv:NonEmptyCollectionToVisibilityConverter x:Key="NonEmptyToVisibility" />
            <conv:NonEmptyCollectionToBoolConverter x:Key="NonEmptyToBool" />
            <conv:StringEqualsConverter x:Key="StringEquals" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
