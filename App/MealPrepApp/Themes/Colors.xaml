<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================
         Palette — olive / cream / dark brown (ported from AppColors.cs)
         ============================================================ -->
    <Color x:Key="MossColor">#FF8C9657</Color>
    <Color x:Key="MossDarkColor">#FF6B7340</Color>
    <Color x:Key="MossLightColor">#FFB5BE88</Color>
    <Color x:Key="DarkColor">#FF2E2820</Color>
    <Color x:Key="CreamColor">#FFF0E5C7</Color>
    <Color x:Key="Cream2Color">#FFE8DDB8</Color>
    <Color x:Key="SidebarColor">#FFDDD5B0</Color>
    <Color x:Key="SearchBgColor">#FF9AA070</Color>
    <Color x:Key="TableAltColor">#FFE8E4CC</Color>
    <Color x:Key="TableSelColor">#FFC8D4A0</Color>
    <Color x:Key="DividerColor">#FFA0A078</Color>

    <!-- Meal-slot accent colors (Breakfast / Lunch / Dinner / Snack) -->
    <Color x:Key="MealBreakfastColor">#FFB5D4B5</Color>
    <Color x:Key="MealLunchColor">#FFA8C4E0</Color>
    <Color x:Key="MealDinnerColor">#FFE0B8A8</Color>
    <Color x:Key="MealSnackColor">#FFE8D89A</Color>

    <!-- Semantic accents -->
    <Color x:Key="DangerColor">#FF8A2010</Color>
    <Color x:Key="WarningColor">#FFC0A040</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="MossBrush" Color="{StaticResource MossColor}" />
    <SolidColorBrush x:Key="MossDarkBrush" Color="{StaticResource MossDarkColor}" />
    <SolidColorBrush x:Key="MossLightBrush" Color="{StaticResource MossLightColor}" />
    <SolidColorBrush x:Key="DarkBrush" Color="{StaticResource DarkColor}" />
    <SolidColorBrush x:Key="CreamBrush" Color="{StaticResource CreamColor}" />
    <SolidColorBrush x:Key="Cream2Brush" Color="{StaticResource Cream2Color}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="SearchBgBrush" Color="{StaticResource SearchBgColor}" />
    <SolidColorBrush x:Key="TableAltBrush" Color="{StaticResource TableAltColor}" />
    <SolidColorBrush x:Key="TableSelBrush" Color="{StaticResource TableSelColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />
    <SolidColorBrush x:Key="MealBreakfastBrush" Color="{StaticResource MealBreakfastColor}" />
    <SolidColorBrush x:Key="MealLunchBrush" Color="{StaticResource MealLunchColor}" />
    <SolidColorBrush x:Key="MealDinnerBrush" Color="{StaticResource MealDinnerColor}" />
    <SolidColorBrush x:Key="MealSnackBrush" Color="{StaticResource MealSnackColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

    <!-- ============================================================
         Typography
         ============================================================ -->
    <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>

    <sys:Double x:Key="FontSizeTitle">18</sys:Double>
    <sys:Double x:Key="FontSizeHeader">14</sys:Double>
    <sys:Double x:Key="FontSizeAction">15</sys:Double>
    <sys:Double x:Key="FontSizeMenu">15</sys:Double>
    <sys:Double x:Key="FontSizeBody">13</sys:Double>
    <sys:Double x:Key="FontSizeSmall">12</sys:Double>

</ResourceDictionary>
